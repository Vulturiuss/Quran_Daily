# Optional connected services. The local-first MVP runs without these values.
EXPO_PUBLIC_SUPABASE_URL=
# Recommended for new Supabase projects.
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy projects can keep using the anon key during migration.
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Enable Google and Apple providers in Supabase Auth, then allow:
# qurandaily://auth/callback (production) and the Expo development callback URL.
# RevenueCat: use the Test Store key during development, then platform keys in production.
EXPO_PUBLIC_REVENUECAT_TEST_KEY=
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
EXPO_PUBLIC_REVENUECAT_WEB_KEY=
EXPO_PUBLIC_REVENUECAT_PREMIUM_ENTITLEMENT=premium
EXPO_PUBLIC_REVENUECAT_FAMILY_ENTITLEMENT=family
# Set to false only if the Family product is not published yet.
EXPO_PUBLIC_ENABLE_FAMILY_PLAN=true
# Secrets for the Supabase revenuecat-webhook Edge Function.
# Configure them with `supabase secrets set`; never expose them with EXPO_PUBLIC_.
REVENUECAT_WEBHOOK_AUTHORIZATION=
REVENUECAT_SECRET_API_KEY=
REVENUECAT_PREMIUM_ENTITLEMENT=premium
REVENUECAT_FAMILY_ENTITLEMENT=family
EXPO_PUBLIC_TERMS_URL=
EXPO_PUBLIC_PRIVACY_URL=
EXPO_PUBLIC_DEVELOPER_NAME=Quran Daily
EXPO_PUBLIC_SUPPORT_EMAIL=
EXPO_PUBLIC_APP_URL=
EXPO_PUBLIC_POSTHOG_KEY=
