{
  "expo": {
    "name": "Quran Daily",
    "slug": "quran-daily",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/quran-daily-icon.png",
    "scheme": "qurandaily",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.qurandaily.app"
    },
    "android": {
      "permissions": [
        "com.android.vending.BILLING"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#10251B"
      },
      "package": "com.qurandaily.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#10251B",
          "image": "./assets/quran-daily-icon.png",
          "imageWidth": 180,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#D4AF37",
          "defaultChannel": "daily-reminders"
        }
      ],
      "expo-font",
      "expo-audio",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
