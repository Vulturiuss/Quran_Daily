{
  "expo": {
    "name": "Quran Daily",
    "slug": "quran-daily",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/quran-daily-icon.png",
    "scheme": "qurandaily",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.qurandaily.app"
    },
    "android": {
      "permissions": [
        "com.android.vending.BILLING",
        "android.permission.RECORD_AUDIO"
      ],
      "blockedPermissions": [
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#134E4A"
      },
      "package": "com.qurandaily.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#134E4A",
          "image": "./assets/quran-daily-icon.png",
          "imageWidth": 180,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#D4A373",
          "defaultChannel": "daily-reminders"
        }
      ],
      "expo-font",
      [
        "expo-audio",
        {
          "microphonePermission": false,
          "recordAudioAndroid": false,
          "enableBackgroundRecording": false,
          "enableBackgroundPlayback": false
        }
      ],
      "expo-asset",
      "expo-sharing",
      "expo-web-browser",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Quran Daily utilise le micro pour écouter ta récitation et la comparer au texte.",
          "speechRecognitionPermission": "Quran Daily utilise la reconnaissance vocale, sur l’appareil, pour vérifier ta récitation.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c956203b-282d-4a75-99dd-a4b85369e589"
      }
    }
  }
}
