{
  "name": "quran-daily",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "dev-client": "expo start --dev-client",
    "beta:android": "npx eas-cli@latest build --platform android --profile development",
    "friends:android-apk": "npx eas-cli@latest build --platform android --profile preview",
    "beta:ios": "npx eas-cli@latest build --platform ios --profile development",
    "beta:ios-simulator": "npx eas-cli@latest build --platform ios --profile ios-simulator",
    "e2e:maestro": "maestro test e2e/maestro",
    "sync:quran": "node scripts/sync-quran-data.mjs",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "lint": "eslint .",
    "check:env": "node scripts/check-env.mjs",
    "eas-build-pre-install": "node scripts/check-env.mjs",
    "check": "npm run typecheck && npm run lint && npm test"
  },
  "dependencies": {
    "@expo-google-fonts/amiri": "^0.4.1",
    "@expo-google-fonts/nunito": "^0.4.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "12.0.1",
    "@supabase/supabase-js": "^2.108.1",
    "expo": "~56.0.15",
    "expo-asset": "~56.0.17",
    "expo-audio": "~56.0.12",
    "expo-constants": "~56.0.18",
    "expo-dev-client": "~56.0.22",
    "expo-font": "~56.0.7",
    "expo-haptics": "~56.0.3",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.15",
    "expo-notifications": "~56.0.20",
    "expo-router": "~56.2.14",
    "expo-sharing": "~56.0.21",
    "expo-splash-screen": "~56.0.12",
    "expo-status-bar": "~56.0.4",
    "expo-web-browser": "~56.0.5",
    "lucide-react-native": "^1.18.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-purchases": "^10.3.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-view-shot": "5.1.0",
    "react-native-web": "^0.21.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/node": "^25.9.3",
    "@types/react": "~19.2.2",
    "eslint": "^9.39.5",
    "eslint-config-expo": "~56.0.4",
    "tsx": "^4.20.6",
    "typescript": "~6.0.3"
  }
}
